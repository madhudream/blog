---
export interface Props {
  title: string;
  excerpt: string;
  date: string;
  readTime: string;
  category: string;
  image: string;
  link: string;
  index?: number;
}

const { title, excerpt, date, readTime, category, image, link, index = 0 } = Astro.props;
---

<article 
  class="group blog-card rounded-3xl shadow-lg hover:shadow-2xl transition-all duration-500 overflow-hidden border animate-slide-up"
  style={`animation-delay: ${index * 0.1}s; background: var(--theme-card-bg); border-color: var(--theme-card-border);`}
>
  <a href={link} class="block">
    <div class="flex flex-col md:flex-row">
      <div class="md:w-1/3 relative overflow-hidden bg-gradient-to-br aspect-video md:aspect-auto">
        <img 
          src={image} 
          alt={title}
          class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700"
          onerror="this.style.display='none'"
        />
      </div>
      <div class="md:w-2/3 p-8">
        <div class="flex items-center gap-4 mb-4">
          <span 
            class="px-4 py-1.5 text-white rounded-full text-xs font-semibold tracking-wide uppercase"
            style="background: linear-gradient(135deg, var(--theme-primary-from), var(--theme-secondary-from));"
          >
            {category}
          </span>
          <span class="text-sm font-medium" style="color: var(--theme-text-tertiary);">{date}</span>
          <span class="text-sm" style="color: var(--theme-text-tertiary);">• {readTime}</span>
        </div>
        
        <h3 
          class="text-3xl font-bold mb-4 group-hover:text-primary transition-colors"
          style="color: var(--theme-text-primary);"
        >
          {title}
        </h3>
        
        <p class="leading-relaxed mb-5 text-base" style="color: var(--theme-text-secondary);">
          {excerpt}
        </p>
        
        <div 
          class="flex items-center font-semibold group-hover:gap-3 gap-2 transition-all"
          style="color: var(--theme-primary-from);"
        >
          Read full story
          <svg class="w-5 h-5 group-hover:translate-x-2 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </div>
      </div>
    </div>
  </a>
</article>

<style>
  .blog-card:hover {
    box-shadow: 0 25px 50px -12px var(--theme-card-hover);
  }
  
  .group:hover .group-hover\:text-primary {
    color: var(--theme-primary-from);
  }
</style>
