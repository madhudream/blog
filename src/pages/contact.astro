---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact - Madhu's Dream">
  <div class="pt-16 min-h-screen">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
      <!-- Header -->
      <div class="text-center mb-12">
        <h1 
          class="text-5xl md:text-6xl font-bold mb-6 bg-clip-text text-transparent"
          style="background-image: linear-gradient(to right, var(--theme-primary-from), var(--theme-accent-from));"
        >
          Get in Touch
        </h1>
        <p class="text-xl leading-relaxed max-w-2xl mx-auto" style="color: var(--theme-text-secondary);">
          Have a question, feedback, or just want to say hi? I'd love to hear from you!
        </p>
      </div>

      <!-- Contact Card -->
      <div 
        class="rounded-3xl p-12 border shadow-xl"
        style="background: var(--theme-card-bg); border-color: var(--theme-card-border);"
      >
        <div class="text-center mb-8">
          <div class="text-6xl mb-4">📧</div>
          <h2 class="text-3xl font-bold mb-4" style="color: var(--theme-text-primary);">
            Email Me
          </h2>
          <p class="text-lg mb-8" style="color: var(--theme-text-secondary);">
            Click the button below to send me an email. I typically respond within 24-48 hours.
          </p>
          
          <a 
            href="mailto:madhublock@gmail.com"
            class="inline-flex items-center gap-3 px-8 py-4 text-white rounded-full font-semibold text-lg transition-all hover:scale-105 hover:shadow-2xl"
            style="background: linear-gradient(135deg, var(--theme-primary-from), var(--theme-secondary-from));"
          >
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
              <polyline points="22,6 12,13 2,6"/>
            </svg>
            Send Email
          </a>
        </div>

        <!-- Social Links Section (Optional) -->
        <div class="mt-12 pt-8 border-t" style="border-color: var(--theme-card-border);">
          <h3 class="text-2xl font-bold mb-6 text-center" style="color: var(--theme-text-primary);">
            Connect With Me
          </h3>
          <div class="flex flex-wrap justify-center gap-4">
            <!-- GitHub -->
            <a 
              href="https://github.com/madhudream" 
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-2 px-6 py-3 rounded-lg transition-all hover:scale-105"
              style="background: var(--theme-code-inline-bg); color: var(--theme-text-primary);"
            >
              <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
              </svg>
              GitHub
            </a>

            <!-- LinkedIn (Optional) -->
            <a 
              href="https://www.linkedin.com/in/madhukar-anugu-86131a56/" 
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-2 px-6 py-3 rounded-lg transition-all hover:scale-105"
              style="background: var(--theme-code-inline-bg); color: var(--theme-text-primary);"
            >
              <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
                <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/>
              </svg>
              LinkedIn
            </a>
          </div>
        </div>

        <!-- Additional Info -->
        <div class="mt-8 text-center">
          <p class="text-sm" style="color: var(--theme-text-tertiary);">
            Email: <span class="font-mono" style="color: var(--theme-text-secondary);">madhublock@gmail.com</span>
          </p>
        </div>
      </div>

      <!-- Back Button -->
      <div class="mt-12 text-center">
        <a 
          href="/" 
          class="inline-flex items-center font-medium transition-colors"
          style="color: var(--theme-text-secondary);"
        >
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
          </svg>
          Back to Home
        </a>
      </div>
    </div>
  </div>
</Layout>

<style>
  a[href^="mailto:"]:hover,
  a[target="_blank"]:hover {
    filter: brightness(1.1);
  }
</style>
